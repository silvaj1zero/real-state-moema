# Backstage catalog-info.yaml Template — Phase 8
# Generated by: code-anatomist v2.0.0
# Ref: https://backstage.io/docs/features/software-catalog/descriptor-format

apiVersion: backstage.io/v1alpha1
kind: System
metadata:
  name: "{system-name}"
  description: "{system description}"
  annotations:
    code-anatomist/version: "2.0.0"
    code-anatomist/slug: "{slug}"
    code-anatomist/analysis-date: "{ISO date}"
spec:
  owner: "{team or owner}"
  domain: "{business domain}"

---
# One entry per container (C4 L2)
apiVersion: backstage.io/v1alpha1
kind: Component
metadata:
  name: "{container-name}"
  description: "{container description}"
  tags:
    - "{language}"
    - "{framework}"
spec:
  type: service  # service | website | library
  lifecycle: production  # production | experimental | deprecated
  owner: "{team}"
  system: "{system-name}"
  providesApis:
    - "{api-name}"
  consumesApis:
    - "{external-api-name}"
  dependsOn:
    - "component:{other-container}"
    - "resource:{database-name}"

---
# One entry per API
apiVersion: backstage.io/v1alpha1
kind: API
metadata:
  name: "{api-name}"
  description: "{api description}"
spec:
  type: openapi  # openapi | asyncapi | graphql | grpc
  lifecycle: production
  owner: "{team}"
  system: "{system-name}"
  definition: |
    # OpenAPI spec or reference to file
    $text: "{path-to-openapi.yaml}"

---
# One entry per database/resource
apiVersion: backstage.io/v1alpha1
kind: Resource
metadata:
  name: "{database-name}"
  description: "{database description}"
spec:
  type: database  # database | cache | queue | storage
  owner: "{team}"
  system: "{system-name}"
